rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Students collection: users can read/write their own doc; admins can read all
    match /students/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.email in ['admin@srichakraacademy.org'];
    }

    // Assessments collection: users can read/write their own; admins can read all
    match /assessments/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.email in ['admin@srichakraacademy.org'];
    }

    // EOI submissions: anyone can create; admins can read all
    match /eoi_submissions/{docId} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.token.email in ['admin@srichakraacademy.org'];
    }
  }
}
